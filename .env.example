# AnchorFlow — environment variables example
# Create a .env with real values (not committed to git).

# Stellar network
NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Deploy identity (create with: stellar keys generate anchorflow)
SOURCE=anchorflow

# Backend signer secret (live mode). Must be an account that is NOT the USDC issuer.
# If empty, the backend runs in sim mode.
SIGNER_SECRET=

# Contract addresses (filled in after deploy)
INVOICE_CONTRACT_ID=
LENDING_POOL_ID=
PAYROLL_STREAM_ID=
ASSET_CONTRACT=          # USDC testnet Stellar Asset Contract address

# Pool parameters
ADVANCE_BPS=8500         # 85% advance ratio
FEE_BPS=200              # 2% financing discount

# Backend
DATABASE_URL=postgres://localhost:5432/anchorflow
PORT=3001
