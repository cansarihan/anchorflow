# AnchorFlow — ortam değişkenleri örneği
# Gerçek değerlerle .env oluşturun (git'e eklenmez).

# Stellar ağı
NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Deploy kimliği (stellar keys generate anchorflow ile oluşturun)
SOURCE=anchorflow

# Backend imzalayıcı secret'ı (live mod). USDC issuer'ı OLMAYAN bir hesap olmalı.
# Boşsa backend sim modunda çalışır.
SIGNER_SECRET=

# Kontrat adresleri (deploy sonrası doldurulur)
INVOICE_CONTRACT_ID=
LENDING_POOL_ID=
PAYROLL_STREAM_ID=
ASSET_CONTRACT=          # USDC testnet Stellar Asset Contract adresi

# Havuz parametreleri
ADVANCE_BPS=8500         # %85 avans oranı
FEE_BPS=200              # %2 financing iskontosu

# Backend
DATABASE_URL=postgres://localhost:5432/anchorflow
PORT=3001
